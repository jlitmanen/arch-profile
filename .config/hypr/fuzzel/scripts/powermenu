#!/usr/bin/env bash
#
chosen=$(printf "箚맓  Shut down\n箚뮧  Suspend\n箚몥  Reboot\n箚뛽  Log out" \
    | fuzzel --dmenu --config="$HOME/.config/hypr/fuzzel/powermenu.ini")

case "$chosen" in
    *"Shut down")  systemctl poweroff ;;
    *"Suspend")    systemctl suspend ;;
    *"Reboot")     systemctl reboot ;;
    *"Log out")    hyprctl dispatch exit ;;
esac
