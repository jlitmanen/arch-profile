{
  "modules-left": ["ext/workspaces", "dwl/window"],
  "modules-center": ["clock", "custom/notification"],
  "modules-right": [
    "tray",
    "custom/sep",
    "pulseaudio",
    "custom/sep",
    "group/battery",
    "custom/sep",
    "group/network-bt",
    "custom/sep",
    "group/hardware",
    "custom/sep",
    "custom/power",
  ],
  "custom/sep": {
    "format": " | ",
  },
  "ext/workspaces": {
    "format": "{name}",
    "sort-by-number": true,
    "on-click": "activate",
  },
  "dwl/window": {
    "format": "{title}",
    "max-length": 20,
  },

  /** CENTER */
  "clock": {
    "format": "{:%H:%M | %d/%m}",
    "tooltip-format": "<big>{:%Y %B}</big>\n\n<tt><big>{calendar}</big></tt>",
  },
  "custom/notification": {
    "tooltip": true,
    "format": "| notifications {icon} ",
    "format-icons": {
      "notification": "¾▒à½",
      "none": "¾░é£",
      "dnd-notification": "¾░éá",
      "dnd-none": "¾░¬ô",
      "inhibited-notification": "¾░éø",
      "inhibited-none": "¾░¬æ",
      "dnd-inhibited-notification": "¾░éø",
      "dnd-inhibited-none": "¾░¬æ",
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  },

  /** RIGHT */
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "¾░Øş",
    "format-icons": {
      "default": ["´ÇĞ ", "´Çğ ", "´Ç¿ "],
    },
    "on-click": "foot -e wiremix",
  },
  "group/network-bt": {
    "orientation": "horizontal",
    "drawer": {
      "click-to-reveal": true,
      "transition-duration": 500,
      "children-class": "conn-child",
      "transition-left-to-right": true,
    },
    "modules": ["custom/conn", "bluetooth", "network"],
  },
  "custom/conn": {
    "format": "connections",
  },
  "bluetooth": {
    "format": "¾░é»",
    "format-connected": "¾░é▒",
    "on-click": "foot -e bluetui",
  },
  "network": {
    "format-wifi": "´ç½ ",
    "format-disconnected": "¾░û¬ ",
    "on-click": "foot -e impala",
  },

  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["custom/hw", "cpu", "memory"],
    "drawer": {
      "click-to-reveal": true,
      "transition-duration": 500,
      "children-class": "hw-child",
      "transition-left-to-right": true,
    },
  },
  "custom/hw": {
    "format": "hardware",
  },
  "cpu": {
    "interval": 10,
    "format": "´ïø  {usage}%",
    "max-length": 10,
    "on-click": "foot -e btop",
  },
  "memory": {
    "format": "¯┐à  {percentage}%",
    "interval": 5,
    "on-click": "foot -e btop",
  },

  /**
   * Battery
   */
  "group/battery": {
    "orientation": "horizontal",
    "modules": ["battery", "power-profiles-daemon"],
    "drawer": {
      "click-to-reveal": true,
      "transition-duration": 500,
      "children-class": "battery-child",
      "transition-left-to-right": true,
    },
  },
  "battery": {
    "bat": "BAT0",
    "interval": 60,
    "format": "{icon} {capacity}%",
    "format-icons": {
      "default": ["¾░éî "],
      "charging": ["¾░éÅ "],
      "plugged": ["´çĞ "],
    },
    "tooltips": {
      "default": "{time}",
    },
    "max-length": 25,
  },
  "power-profiles-daemon": {
    "format": " {icon}",
    "tooltip-format": "Profile: {profile}\nDriver: {driver}",
    "format-icons": {
      "default": " ´âğ ",
      "performance": " ´âğ ",
      "balanced": " ´ëÄ ",
      "power-saver": " ´ü¼ ",
    },
  },
  "custom/power": {
    "format": "¾░ÉÑ  ",
    "tooltip": false,
    "on-click": "wlogout",
  },
}
